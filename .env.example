# ATLAS environment variables
# Copy this file to .env and fill in your values.
# cp .env.example .env
#
#
# All variables in the REQUIRED section must be set.
# The backend refuses to start if any are missing.

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Neo4j Aura Serverless (console.neo4j.io)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ServiceNow Developer Instance (developer.servicenow.com)
SERVICENOW_INSTANCE_URL=https://devXXXXXX.service-now.com
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=

# Cryptographic signing key for approval tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 characters. Never commit the real value.
ATLAS_SECRET_KEY=

# LLM reasoning endpoint — single-service default (served by backend.main on port 8000)
# For standalone LLM server mode only, point this to that service URL instead.
ATLAS_LLM_ENDPOINT=http://localhost:8000/internal/llm/reason

# SQLite database paths (relative to Atlas/ directory)
CHROMADB_PATH=./data/chromadb
ATLAS_AUDIT_DB_PATH=./data/atlas_audit.db
ATLAS_DECISION_DB_PATH=./data/atlas_decisions.db
ATLAS_CHECKPOINT_DB_PATH=./data/atlas_checkpoints.db

# Cerebras (primary LLM)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# Ollama (optional fallback if Cerebras is unavailable)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:480b-cloud

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Anthropic Claude (fallback LLM if Ollama is unavailable)
ANTHROPIC_API_KEY=

# OpenAI GPT-4o (secondary fallback)
OPENAI_API_KEY=

# Slack incoming webhook for human review notifications
SLACK_WEBHOOK_URL=

# Frontend CORS origin (default: http://localhost:5173)
ATLAS_FRONTEND_ORIGIN=http://localhost:5173
