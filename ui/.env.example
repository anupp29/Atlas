VITE_ATLAS_API_BASE_URL=http://localhost:8000
# Optional. If omitted, the UI derives WS URL from VITE_ATLAS_API_BASE_URL.
# VITE_ATLAS_WS_BASE_URL=ws://localhost:8000

# Polling interval for REST refreshes (in milliseconds).
VITE_ATLAS_POLL_INTERVAL_MS=10000

# Default backend client used in Client Portal mode.
VITE_ATLAS_DEFAULT_CLIENT_ID=FINCORE_UK_001
